# NEUQ 教务系统凭证（必填）
YOUR_NEUQ_USERNAME=你的学号
YOUR_NEUQ_PASSWORD=你的密码

# 教务系统 URL（可选，默认为官方地址）
# NEUQ_JWXT_BASE_URL=http://jwxt.neuq.edu.cn/eams/

# 请求超时时间（秒，默认 45）
# REQUEST_TIMEOUT_SECS=45

# 请求间隔时间（毫秒，默认 2000）
# REQUEST_DELAY_MS=2000

# 总共处理的天数（1-30，默认 7）
# TOTAL_DAYS=7

# 最大重试次数（默认 3）
# MAX_RETRIES=3

# 输出目录（默认 ./output）
# OUTPUT_DIR=./output

# 静态资源目录（默认 ./assets）
# ASSETS_DIR=./assets

# 是否覆盖已有数据（默认 false）
# FORCE_OVERWRITE=false

# 是否压缩 HTML 输出（默认 true）
# MINIFY_HTML=true
